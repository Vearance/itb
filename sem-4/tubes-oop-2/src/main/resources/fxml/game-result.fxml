<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.bananarepublic.ui.controller.GameResultController" alignment="CENTER" spacing="18" styleClass="screen game-result-screen" prefWidth="760" prefHeight="560">
    <padding><Insets top="42" right="54" bottom="42" left="54"/></padding>
    <Label fx:id="winnerLabel" text="Player has founded the Banana Republic!" styleClass="title"/>
    <VBox alignment="CENTER" styleClass="playtime-card">
        <Label text="TOTAL PLAYTIME" styleClass="field-label"/>
        <Label fx:id="playtimeLabel" text="00:00:00" styleClass="timer-large"/>
    </VBox>
    <TableView fx:id="scoreTable" prefHeight="250" maxWidth="660">
        <columns>
            <TableColumn fx:id="playerColumn" text="Player" prefWidth="150"/>
            <TableColumn fx:id="settlementColumn" text="Pos Pantau" prefWidth="100"/>
            <TableColumn fx:id="labColumn" text="Lab" prefWidth="90"/>
            <TableColumn fx:id="specialColumn" text="Kartu Spesial" prefWidth="120"/>
            <TableColumn fx:id="secretColumn" text="Poin Rahasia" prefWidth="120"/>
            <TableColumn fx:id="totalColumn" text="Total" prefWidth="80"/>
        </columns>
    </TableView>
    <HBox spacing="10" alignment="CENTER">
        <Button text="View Final Board" onAction="#handleViewBoard"/>
        <Button text="Main Menu" onAction="#handleMainMenu" styleClass="primary-button"/>
    </HBox>
</VBox>
