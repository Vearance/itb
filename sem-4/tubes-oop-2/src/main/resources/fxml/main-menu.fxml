<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bananarepublic.ui.controller.MainMenuController"
      styleClass="menu-shell">
    <children>
        <StackPane VBox.vgrow="ALWAYS" styleClass="menu-stage">
            <padding>
                <Insets top="110" right="120" bottom="110" left="120"/>
            </padding>
            <VBox alignment="CENTER" spacing="14" prefWidth="345" maxWidth="345" prefHeight="235" maxHeight="235" styleClass="menu-card">
                <children>
                    <Label text="BANANA REPUBLIC" styleClass="menu-logo"/>
                    <Button text="NEW GAME" onAction="#handleNewGame" maxWidth="275" prefHeight="39" styleClass="menu-button"/>
                    <Button text="LOAD GAME" onAction="#handleLoadGame" maxWidth="275" prefHeight="39" styleClass="menu-button"/>
                    <Button text="EXIT" onAction="#handleExit" maxWidth="275" prefHeight="39" styleClass="menu-button"/>
                </children>
            </VBox>
        </StackPane>
    </children>
</VBox>
